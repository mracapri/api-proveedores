<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

<html lang="es" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta content="text/html; charset=utf-8" http-equiv="Content-Type" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Cuenta Activada - Grupo Martí</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <style type="text/css">
            /* Client-specific Styles */
            body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
            table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
            img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
            table { border-collapse: collapse ! invasion; }
            body { height: 100% !important; margin: 0 !important; padding: 0 !important; width: 100% !important; background-color: #faf8ff; font-family: 'Manrope', Arial, sans-serif; }

            /* iOS BLUE LINKS */
            a[x-apple-data-detectors] {
                color: inherit !important;
                text-decoration: none !important;
                font-size: inherit !important;
                font-family: inherit !important;
                font-weight: inherit !important;
                line-height: inherit !important;
            }

            /* Mobile Styles */
            @@media screen and (max-width: 600px) {
                .main-table { width: 100% !important; }
                .content-padding { padding: 30px 20px !important; }
                .header-padding { padding: 20px !important; }
            }
    </style>
</head>
<body style="margin: 0; padding: 0; background-color: #faf8ff;">
    <center>
        <table border="0" cellpadding="0" cellspacing="0" style="table-layout: fixed; background-color: #faf8ff;" width="100%">
            <tbody>
                <tr>
                    <td align="center" style="padding: 40px 0;">
                        <!-- Email Container -->
                        <table border="0" cellpadding="0" cellspacing="0" class="main-table" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e1e1ee;" width="600">
                            <!-- Header -->
                            <tbody>
                                <tr>
                                    <td align="center" class="header-padding" style="background-color: #135bec; padding: 32px 40px;">
                                        <img alt="Grupo Martí Logo" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC67yD9Vcevf65EHL-x2EU0JSODVPLTXXrxva6wv_5aQe0pDYlHadA_sHnbfQmybU7OKhGHeH1KWQB6iJi2YV73AlGIhOkoe7MHSEl7LmUUcSojGNS6LIDZzY5vTozvN9bCnLLRddumxe0GqwKGayxmE2KJX0UhgvswmhGWHap5rF84cpKMVr5nEg3lD76Yg36NrTPi79kufwt10yk5Gyv3ONuzsw-xsLA28hDLEPicWn2Qa1dtl9rA8ONQLayE8-0YBBZR685jkXg5" style="display: block; width: 180px; max-width: 100%;" width="180" />
                                    </td>
                                </tr>
                                <!-- Hero Icon Section (Visual Anchor from SCREEN_8) -->
                                <tr>
                                    <td align="center" style="padding: 40px 40px 0 40px;">
                                        <div style="width: 64px; height: 64px; background-color: #e2e6ff; border-radius: 50%; display: inline-block; text-align: center; line-height: 70px;">
                                            <span style="font-size: 32px; color: #135bec; font-weight: bold;">✓</span>
                                        </div>
                                    </td>
                                </tr>
                                <!-- Content Body -->
                                <tr>
                                    <td class="content-padding" style="padding: 30px 50px 40px 50px; text-align: center;">
                                        <h1 style="color: #191b24; font-size: 24px; font-weight: 800; line-height: 32px; margin: 0 0 16px 0; letter-spacing: -0.025em;">
                                            ¡Tu cuenta ha sido activada con éxito!
                                        </h1>
                                        <p style="color: #434655; font-size: 16px; font-weight: 400; line-height: 24px; margin: 0 0 32px 0;">
                                            Hola <strong style="color: #191b24;">@Model.payload.nombre</strong>, te informamos que tu cuenta en el Portal de Proveedores de Grupo Martí ya se encuentra activa y lista para usarse.
                                        </p>
                                        <!-- Action Button -->
                                        <table border="0" cellpadding="0" cellspacing="0" style="margin: 0 auto;">
                                            <tbody>
                                                <tr>
                                                    <td align="center" bgcolor="#135bec" style="border-radius: 4px;">
                                                        <a href="@Model.payload.url" style="font-size: 14px; font-weight: 700; color: #ffffff; text-decoration: none; padding: 14px 40px; border-radius: 4px; display: inline-block; text-transform: uppercase; letter-spacing: 0.05em;" target="_blank">
                                                            Iniciar Sesión
                                                        </a>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <!-- Next Steps Section -->
                                        <table border="0" cellpadding="0" cellspacing="0" style="margin-top: 40px; border-top: 1px solid #e1e1ee; padding-top: 32px;" width="100%">
                                            <tbody>
                                                <tr>
                                                    <td align="left">
                                                        <p style="color: #191b24; font-size: 14px; font-weight: 700; margin: 0 0 12px 0;">¿Qué puedes hacer ahora?</p>
                                                        <p style="color: #585e6d; font-size: 14px; font-weight: 400; line-height: 20px; margin: 0;">
                                                            Desde este momento tienes acceso completo para:
                                                        </p>
                                                        <ul style="color: #585e6d; font-size: 14px; font-weight: 400; line-height: 24px; margin: 12px 0 0 0; padding-left: 20px; text-align: left;">
                                                            <li>Cargar y consultar el estado de tus facturas.</li>
                                                            <li>Generar reportes de facturas</li>
                                                            <li>Revisar el historial de facturas.</li>
                                                            <li>Recibir soporte directo de nuestro equipo administrativo.</li>
                                                        </ul>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                                <!-- Footer Area -->
                                <tr>
                                    <td align="center" style="background-color: #f3f3ff; padding: 32px 40px; border-top: 1px solid #e1e1ee;">
                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                            <tbody>
                                                <tr>
                                                    <td align="center" style="padding-bottom: 16px;">
                                                        <p style="color: #737687; font-size: 12px; font-weight: 500; margin: 0; line-height: 18px;">
                                                            Este es un mensaje automático, por favor no respondas a esta dirección de correo.
                                                        </p>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td align="center">
                                                        <p style="margin: 0;">
                                                            <a href="#" style="color: #135bec; font-size: 12px; font-weight: 600; text-decoration: none; margin: 0 10px;">Aviso de Privacidad</a>
                                                            <span style="color: #c3c5d8;">|</span>
                                                            <a href="#" style="color: #135bec; font-size: 12px; font-weight: 600; text-decoration: none; margin: 0 10px;">Términos y Condiciones</a>
                                                        </p>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td align="center" style="padding-top: 24px;">
                                                        <p style="color: #737687; font-size: 11px; font-weight: 400; margin: 0; text-transform: uppercase; letter-spacing: 0.1em;">
                                                            © 2026 GRUPO MARTÍ.
                                                        </p>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <!-- Bottom Spacing -->
                        <table border="0" cellpadding="0" cellspacing="0" class="main-table" width="600">
                            <tbody>
                                <tr>
                                    <td style="padding: 20px 0; text-align: center;">
                                        <p style="color: #737687; font-size: 11px; font-weight: 400; margin: 0;">
                                            Si no reconoces esta actividad, por favor contacta a <a href="mailto:soporte@marti.com.mx" style="color: #135bec; text-decoration: underline;">soporte@marti.com.mx</a> inmediatamente.
                                        </p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
            </tbody>
        </table>
    </center>
</body></html>